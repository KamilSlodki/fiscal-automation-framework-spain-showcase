%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#2962FF', 'secondaryColor': '#00C853', 'tertiaryColor': '#FF6D00'}}}%%

flowchart TB
    subgraph cli["CLI Layer"]
        TYPER["Typer 0.9 + Rich<br/>comandos por capa"]
    end

    subgraph c1["Capa 1 - Intake"]
        PDF_PARSE["pdfplumber<br/>extraccion PDF"]
        OCR["pytesseract + Pillow<br/>fallback imagenes"]
        XLS["openpyxl + pandas<br/>extractos bancarios"]
        CHECKS["5 checks alto nivel<br/>doble lectura · fecha ·<br/>rango · trimestre · recalculo"]
    end

    subgraph c2["Capa 2 - Classification"]
        MAP_YAML["Catalogo YAML<br/>proveedor -> categoria AEAT<br/>determinista · NO LLM"]
        RULES["Reglas deducibilidad<br/>art 30-32 LIRPF<br/>art 96 LIVA"]
    end

    subgraph c3["Capa 3 - Math Engine"]
        DEC["Decimal stdlib<br/>tolerance 0.02 EUR<br/>IN-006: NO float"]
        IVA_CALC["IVA: base x tipo<br/>0% · 4% · 10% · 21%"]
        IRPF_CALC["IRPF 130: pagos fraccionados<br/>con reglas exencion LIRPF"]
        AMORT["Amortizaciones lineales<br/>coeficientes por categoria"]
    end

    subgraph c4_layer["Capa 4 - Validation (4 sub-capas)"]
        V_FORMAL["Formal<br/>RD 1619/2012 campos obligatorios"]
        V_REAL["Realidad<br/>CIF formato + checksum"]
        V_CENSAL["Censal<br/>alta AEAT cuando aplica"]
        V_DUP["Duplicados<br/>SHA-256 vs manifest historico"]
    end

    subgraph c5["Capa 5 - Reconciliation"]
        RECON["Ledger contable vs extracto bancario<br/>tolerance 0.02 EUR<br/>huerfanos bidireccionales"]
    end

    subgraph c6["Capa 6 - AEAT Models"]
        M303["Modelo 303<br/>IVA trimestral"]
        M130["Modelo 130<br/>IRPF pagos fraccionados"]
        M349["Modelo 349<br/>intracomunitarias"]
        M390["Modelo 390<br/>resumen anual"]
    end

    subgraph c7["Capa 7 - Release & Audit"]
        MANIFEST["manifest.json<br/>SHA-256 inputs + outputs"]
        REP_VAL["validity_report.json"]
        REP_OCR["ocr_audit.json"]
        REP_CLS["classification_audit.json"]
        REP_REC["reconciliation_report.json"]
        REP_REL["release_report.md<br/>resumen ejecutivo"]
    end

    subgraph cross["Cross-cutting"]
        PYDANTIC["Pydantic 2.0<br/>4 JSON Schemas"]
        FSM["FSM 6 estados<br/>RAW -> PARSED -> NORMALIZED -><br/>VALIDATED -> RECONCILED -> APPROVED · BLOCKED"]
        INV["9 invariantes IN-001..IN-009<br/>validables via grep"]
        TESTS["pytest<br/>suite completa paths criticos"]
    end

    TYPER --> PDF_PARSE
    TYPER --> OCR
    TYPER --> XLS
    PDF_PARSE --> CHECKS
    OCR --> CHECKS
    CHECKS --> MAP_YAML
    XLS --> RECON
