    DEC --> IVA_CALC
    DEC --> IRPF_CALC
    DEC --> AMORT
    IVA_CALC --> V_FORMAL
    IRPF_CALC --> V_FORMAL
    AMORT --> V_FORMAL
    V_FORMAL --> V_REAL
    V_REAL --> V_CENSAL
    V_CENSAL --> V_DUP
    V_DUP --> RECON
    RECON --> M303
    RECON --> M130
    RECON --> M349
    RECON --> M390
    M303 --> MANIFEST
    M130 --> MANIFEST
    M349 --> MANIFEST
    M390 --> MANIFEST
    MANIFEST --> REP_VAL
    MANIFEST --> REP_OCR
    MANIFEST --> REP_CLS
    MANIFEST --> REP_REC
    MANIFEST --> REP_REL

    PYDANTIC -.-> CHECKS
    PYDANTIC -.-> V_FORMAL
    FSM -.-> CHECKS
    FSM -.-> V_FORMAL
    FSM -.-> RECON
    INV -.-> DEC
    INV -.-> MANIFEST
    TESTS -.-> DEC
    TESTS -.-> V_FORMAL

